# Stocksie frontend environment (copy to .env.local for local overrides).
# All vars are client-exposed (NEXT_PUBLIC_*) because the UI runs in the browser.

# Surfpool local RPC (localnet). Start Surfpool in local mode, then point here.
# Surfpool default RPC: http://127.0.0.1:8899
NEXT_PUBLIC_RPC_ENDPOINT=http://127.0.0.1:8899

# Commitment level for reads/transactions (processed | confirmed | finalized).
NEXT_PUBLIC_RPC_COMMITMENT=confirmed

# Stocksie program id (must match Anchor.toml [programs.localnet] stocksie).
NEXT_PUBLIC_PROGRAM_ID=At2vd5Mqd9xcHRFAZin1VHb6upEsF1GCXoFG19UHsQoj
